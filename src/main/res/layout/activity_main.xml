<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITLE -->
        <TextView
            android:text="Select Machine"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- MACHINE BUTTON -->
        <Button
            android:id="@+id/showMachinesBtn"
            android:text="Select Machine"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <!-- MACHINE LIST -->
        <RadioGroup
            android:id="@+id/radioGroup"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <!-- HOURS -->
        <EditText
            android:id="@+id/hours"
            android:hint="Enter hours"
            android:inputType="number"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"/>

        <!-- DATE -->
        <EditText
            android:id="@+id/date"
            android:hint="Select Date"
            android:focusable="false"
            android:clickable="true"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <!-- TOTAL PRICE -->
        <TextView
            android:id="@+id/totalPrice"
            android:text="Total Price: ₹0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- BOOK BUTTON -->
        <Button
            android:id="@+id/bookBtn"
            android:text="Book Machine"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"/>

        <!-- SHOW REQUESTS BUTTON -->
        <Button
            android:id="@+id/showRequestsBtn"
            android:text="Your Requests"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"/>

        <!-- OUTPUT -->
        <LinearLayout
            android:id="@+id/outputContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

</ScrollView>