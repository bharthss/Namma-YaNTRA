<resources>

    <style name="Theme.NammaYantra" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#2563EB</item>
        <item name="colorPrimaryDark">#1E40AF</item>
        <item name="colorAccent">#22C55E</item>
    </style>

    <style name="Theme.NammaYantra.Splash" parent="Theme.SplashScreen">

        <!-- Background color -->
        <item name="windowSplashScreenBackground">@android:color/white</item>

        <!-- Your logo -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>

        <!-- After splash, go to main theme -->
        <item name="postSplashScreenTheme">@style/Theme.NammaYantra</item>

    </style>

</resources>